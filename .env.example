# Application
APP_ENV=development
APP_LOG_LEVEL=INFO

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000

# API and database
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
DATABASE_URL=postgresql+psycopg://aim:aim@localhost:5432/aim
JWT_SECRET_KEY=replace-with-a-local-development-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Queue
REDIS_URL=redis://localhost:6379/0
SCAN_SCHEDULER_INTERVAL_SECONDS=60

# Email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10
ALERT_DELIVERY_BATCH_SIZE=25

# Scanner
SCANNER_TIMEOUT_SECONDS=10
SCANNER_MAX_REDIRECTS=5
SCANNER_MAX_RESPONSE_BYTES=1048576
SSL_INSPECTION_TIMEOUT_SECONDS=10
LIGHTHOUSE_COMMAND=corepack pnpm exec lighthouse
LIGHTHOUSE_TIMEOUT_SECONDS=180

# AI diagnosis narrative
# Leave ANTHROPIC_API_KEY empty to use the deterministic report generator.
ANTHROPIC_API_KEY=
AI_REPORT_MODEL=claude-opus-4-8
AI_REPORT_LLM_TIMEOUT_SECONDS=30
AI_REPORT_LLM_MAX_RETRIES=1
AI_REPORT_LLM_MAX_TOKENS=16000

# Artifact storage
ARTIFACT_STORAGE_BACKEND=local
ARTIFACT_LOCAL_ROOT=artifacts
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=aim
MINIO_SECRET_KEY=replace-with-a-local-development-secret
MINIO_BUCKET=aim-artifacts
