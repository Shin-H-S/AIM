# AIM production environment example for GCP VM + Docker Compose.
# Copy this file to `.env.production` on the VM and replace every placeholder value.

# Application
APP_ENV=production
APP_LOG_LEVEL=INFO

# Public hostnames
# Use two DNS records that point to the VM static external IP.
AIM_WEB_HOSTNAME=aim.example.com
AIM_API_HOSTNAME=api.aim.example.com

# Web
# NEXT_PUBLIC_API_URL is baked into the Next.js production build.
# Rebuild the web image after changing this value.
NEXT_PUBLIC_API_URL=https://api.aim.example.com

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=["https://aim.example.com"]
JWT_SECRET_KEY=replace-with-a-long-random-production-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# PostgreSQL
POSTGRES_DB=aim
POSTGRES_USER=aim
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql+psycopg://aim:replace-with-a-strong-database-password@postgres:5432/aim

# Redis / Celery
REDIS_URL=redis://redis:6379/0
SCAN_SCHEDULER_INTERVAL_SECONDS=60
CELERY_WORKER_CONCURRENCY=1

# Email alerts
# Leave empty to record alerts without sending email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10
ALERT_DELIVERY_BATCH_SIZE=25
# Slack/Discord webhook alerts (per-project URLs are stored in the DB).
ALERT_WEBHOOK_TIMEOUT_SECONDS=10

# Scanner
SCANNER_TIMEOUT_SECONDS=10
SCANNER_MAX_REDIRECTS=5
SCANNER_MAX_RESPONSE_BYTES=1048576
SSL_INSPECTION_TIMEOUT_SECONDS=10
LIGHTHOUSE_COMMAND=lighthouse
LIGHTHOUSE_TIMEOUT_SECONDS=180

# AI diagnosis narrative
# Leave ANTHROPIC_API_KEY empty to use the deterministic report generator.
ANTHROPIC_API_KEY=
AI_REPORT_MODEL=claude-opus-4-8
AI_REPORT_LLM_TIMEOUT_SECONDS=30
AI_REPORT_LLM_MAX_RETRIES=1
AI_REPORT_LLM_MAX_TOKENS=16000

# Artifact storage
# Local artifact storage is the only implemented backend today.
ARTIFACT_STORAGE_BACKEND=local
ARTIFACT_LOCAL_ROOT=/data/aim/artifacts

# Reserved for future MinIO/GCS support.
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=aim
MINIO_SECRET_KEY=replace-with-a-production-secret
MINIO_BUCKET=aim-artifacts
